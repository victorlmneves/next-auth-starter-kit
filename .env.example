# ============================================================
# Next.js Auth Start Kit - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control!
# ============================================================

# NextAuth.js Configuration
# Generate a secret: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# The base URL of your application
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# Auth0 Configuration
# ============================================================
# Create an application at https://manage.auth0.com
AUTH_AUTH0_ID=your-auth0-client-id
AUTH_AUTH0_SECRET=your-auth0-client-secret
AUTH_AUTH0_ISSUER=https://your-tenant.auth0.com

# Auth0 Management API (for refresh tokens)
AUTH0_AUDIENCE=https://your-tenant.auth0.com/api/v2/
AUTH0_SCOPE=openid profile email offline_access

# ============================================================
# Optional OAuth Providers
# ============================================================

# GitHub OAuth
# Create at: https://github.com/settings/applications/new
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# Google OAuth
# Create at: https://console.developers.google.com
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# ============================================================
# Database (optional, for sessions/users)
# ============================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ============================================================
# Application Settings
# ============================================================
NEXT_PUBLIC_APP_NAME="Next Auth Start Kit"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.0

# Feature flags
NEXT_PUBLIC_ENABLE_GITHUB_AUTH=true
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
